---
const navLinks = [
  { href: '/recast/', label: 'Recast' },
  { href: '/pmi-removal/', label: 'PMI Removal' },
  { href: '/biweekly-payoff/', label: 'Biweekly' },
  { href: '/arm-reset/', label: 'ARM Reset' },
  { href: '/heloc-vs-refi/', label: 'HELOC vs Refi' },
  { href: '/buy-vs-rent/', label: 'Buy vs Rent' },
  { href: '/guides/', label: 'Guides' },
];

const currentPath = Astro.url.pathname;
---

<header class="border-b border-ink-200 bg-cream sticky top-0 z-40 backdrop-blur-sm bg-cream/95">
  <div class="max-w-content mx-auto px-4 lg:px-6">
    <div class="flex items-center justify-between h-16">
      <a href="/" class="flex items-center hover:opacity-80 transition-opacity" aria-label="RecastCalc home">
        <img
          src="/logo.svg"
          alt="RecastCalc"
          width="180"
          height="34"
          class="h-8 w-auto"
        />
      </a>

      <nav aria-label="Primary" class="hidden lg:flex items-center gap-1">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              'px-3 py-2 text-sm font-medium transition-colors',
              currentPath.startsWith(link.href) && link.href !== '/'
                ? 'text-accent'
                : 'text-ink-700 hover:text-ink-900',
            ]}
          >
            {link.label}
          </a>
        ))}
      </nav>

      <button
        type="button"
        id="mobile-menu-toggle"
        class="lg:hidden p-2 text-ink-700"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <nav id="mobile-menu" aria-label="Mobile" class="hidden lg:hidden pb-4 border-t border-ink-100 pt-2">
      {navLinks.map((link) => (
        <a href={link.href} class="block px-3 py-2 text-sm font-medium text-ink-700 hover:text-accent">
          {link.label}
        </a>
      ))}
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('hidden');
    toggle.setAttribute('aria-expanded', String(!isOpen));
  });
</script>
