---
export interface Props {
  title: string;
  description: string;
  ctaText: string;
  href: string;
  partner?: string;
}

const { title, description, ctaText, href, partner } = Astro.props;
---

<aside class="cta-card not-prose">
  {partner && (
    <p class="text-[10px] uppercase tracking-widest text-accent font-semibold mb-1">
      Sponsored · {partner}
    </p>
  )}
  <h3 class="font-display text-lg font-semibold text-ink-900 mb-2">{title}</h3>
  <p class="text-sm text-ink-700 mb-4">{description}</p>
  <a
    href={href}
    rel="sponsored nofollow noopener"
    target="_blank"
    class="inline-flex items-center gap-2 text-sm font-semibold text-accent hover:text-accent-600 underline underline-offset-4 decoration-2 decoration-accent/40 hover:decoration-accent"
  >
    {ctaText}
    <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
      <path d="M7 17L17 7M17 7H8M17 7V16" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  </a>
</aside>
