---
/* Biweekly Payoff Calculator
 * Vanilla JS island, mirrors RecastCalculator.astro structure */

import rates from '../data/rates.json';
const r30 = rates.rates["30yr_fixed"];
const r15 = rates.rates["15yr_fixed"];
const rArm = rates.rates["5_1_arm"];
const rHeloc = rates.rates["heloc"];
const rPmi = rates.rates["pmi_typical"];

---

<section
  id="biweekly-calculator"
  class="bg-cream-50 border border-ink-200 rounded-lg p-6 md:p-8 shadow-sm"
  aria-labelledby="calculator-heading"
>
  <h2 id="calculator-heading" class="font-display text-2xl font-semibold text-ink-900 mb-2">
    Calculate biweekly mortgage savings (and the free DIY equivalent)
  </h2>
  <p class="text-sm text-ink-600 mb-6">
    Enter your balance, rate, and term. See exactly how much a biweekly program saves, how much you can save free with monthly + 1/12, and what the program fee actually costs you.
  </p>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
    <!-- INPUTS -->
    <form id="biweekly-form" novalidate>
      <div class="space-y-5">
        <div>
          <label for="balance" class="calc-label">Current loan balance</label>
          <div class="relative">
            <span class="absolute left-3 top-1/2 -translate-y-1/2 text-ink-400 font-mono">$</span>
            <input type="number" id="balance" name="balance" class="calc-input pl-7"
              placeholder="400,000" min="1000" max="10000000" step="1000" value="400000" required inputmode="numeric" />
          </div>
        </div>

        <div>
          <label for="rate" class="calc-label">Interest rate (annual)</label>
          <div class="relative">
            <input type="number" id="rate" name="rate" class="calc-input pr-8"
              placeholder={r30.toString()} min="0" max="25" step="0.001" value={r30} required inputmode="decimal" />
            <span class="absolute right-3 top-1/2 -translate-y-1/2 text-ink-400 font-mono">%</span>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div>
            <label for="termYears" class="calc-label">Years remaining</label>
            <input type="number" id="termYears" name="termYears" class="calc-input"
              placeholder="30" min="1" max="50" step="1" value="30" required inputmode="numeric" />
          </div>
          <div>
            <label for="termMonths" class="calc-label">Plus months</label>
            <input type="number" id="termMonths" name="termMonths" class="calc-input"
              placeholder="0" min="0" max="11" step="1" value="0" inputmode="numeric" />
          </div>
        </div>

        <div>
          <label for="programFee" class="calc-label">
            Total biweekly program fee
            <span class="text-ink-400 font-normal">(setup + per-payment, over loan life)</span>
          </label>
          <div class="relative">
            <span class="absolute left-3 top-1/2 -translate-y-1/2 text-ink-400 font-mono">$</span>
            <input type="number" id="programFee" name="programFee" class="calc-input pl-7"
              placeholder="3,500" min="0" max="20000" step="100" value="3500" inputmode="numeric" />
          </div>
        </div>
      </div>
    </form>

    <!-- RESULTS -->
    <div id="biweekly-results" aria-live="polite" aria-atomic="true">
      <div class="bg-cream-200 rounded-lg p-5 mb-4">
        <p class="text-xs uppercase tracking-widest text-ink-500 mb-1">Your free DIY savings</p>
        <div class="grid grid-cols-2 gap-4 mt-3">
          <div>
            <p class="text-xs text-ink-500 mb-1">Pay each month, plus</p>
            <p class="calc-result text-2xl" data-result="oneTwelfthExtra">$211</p>
          </div>
          <div>
            <p class="text-xs text-ink-500 mb-1">Standard monthly payment</p>
            <p class="calc-result text-2xl text-ink-500" data-result="standardPayment">$2,528</p>
          </div>
        </div>
        <div class="mt-4 pt-4 border-t border-ink-300/50">
          <p class="text-xs text-ink-500 mb-1">Interest you save</p>
          <p class="calc-result text-3xl text-positive" data-result="diyInterestSavings">$116,342</p>
          <p class="text-xs text-ink-500 mt-1">
            Pays off <span data-result="diyMonthsSaved">70 months</span> early · zero fee · same math as biweekly
          </p>
        </div>
      </div>

      <!-- The honest comparison: 3 strategies -->
      <div class="border border-ink-200 rounded-lg overflow-hidden text-sm">
        <div class="bg-cream-200 px-4 py-2 text-xs font-semibold uppercase tracking-wider text-ink-700 border-b border-ink-200">
          Three strategies, side-by-side
        </div>
        <table class="w-full">
          <thead>
            <tr class="text-left text-xs text-ink-500 border-b border-ink-200">
              <th class="px-4 py-2 font-medium">Strategy</th>
              <th class="px-4 py-2 font-medium text-right">Total interest</th>
              <th class="px-4 py-2 font-medium text-right">Net cost</th>
            </tr>
          </thead>
          <tbody class="font-mono tabular text-ink-800">
            <tr class="border-b border-ink-100">
              <td class="px-4 py-3 font-sans text-ink-700">
                <span class="block font-medium">Standard monthly</span>
                <span class="text-xs text-ink-400">Pay only what's due</span>
              </td>
              <td class="px-4 py-3 text-right" data-result="standardInterest">$510,178</td>
              <td class="px-4 py-3 text-right" data-result="standardNetCost">$510,178</td>
            </tr>
            <tr class="border-b border-ink-100">
              <td class="px-4 py-3 font-sans text-ink-700">
                <span class="block font-medium">Biweekly via program</span>
                <span class="text-xs text-ink-400">26 half-payments per year, with fee</span>
              </td>
              <td class="px-4 py-3 text-right" data-result="biweeklyInterest">$393,836</td>
              <td class="px-4 py-3 text-right" data-result="biweeklyNetCost">$397,418</td>
            </tr>
            <tr class="bg-accent-50/30">
              <td class="px-4 py-3 font-sans text-ink-900 font-medium">
                <span class="block">Monthly + 1/12 extra</span>
                <span class="text-xs text-ink-500 font-normal">Same savings, no fee</span>
              </td>
              <td class="px-4 py-3 text-right" data-result="diyInterest">$393,836</td>
              <td class="px-4 py-3 text-right" data-result="diyNetCost">$393,836</td>
            </tr>
          </tbody>
        </table>
      </div>

      <p
        id="best-strategy-callout"
        class="mt-4 text-sm text-ink-700 leading-relaxed"
        data-result="strategyCallout"
      >
        Loading...
      </p>

      <div class="mt-4 flex flex-wrap gap-3">
        <button type="button" id="copy-link-btn"
          class="text-xs text-ink-600 hover:text-accent underline underline-offset-2 decoration-ink-300 hover:decoration-accent">
          Copy link to these results
        </button>
        <button type="button" id="print-btn" onclick="window.print()"
          class="text-xs text-ink-600 hover:text-accent underline underline-offset-2 decoration-ink-300 hover:decoration-accent">
          Print / save as PDF
        </button>
      </div>

      <p class="text-xs text-ink-400 mt-4 leading-relaxed">
        Estimates only. Includes principal and interest only; excludes taxes, insurance, and escrow.
        Biweekly programs fees vary widely; check your servicer's specific terms before enrolling.
      </p>
    </div>
  </div>
</section>

<script>
  import { calculateBiweekly, formatCurrency, formatDuration } from '../scripts/mortgage-math.js';

  const form = document.getElementById('biweekly-form');
  const inputs = form.querySelectorAll('input');

  function getInputs() {
    return {
      currentBalance: parseFloat(document.getElementById('balance').value) || 0,
      annualRate: parseFloat(document.getElementById('rate').value) || 0,
      remainingTermMonths:
        (parseInt(document.getElementById('termYears').value) || 0) * 12 +
        (parseInt(document.getElementById('termMonths').value) || 0),
      programFee: parseFloat(document.getElementById('programFee').value) || 0,
    };
  }

  function setResult(key, value) {
    const el = document.querySelector(`[data-result="${key}"]`);
    if (el) el.textContent = value;
  }

  function update() {
    const params = getInputs();
    const result = calculateBiweekly(params);

    if (!result) {
      setResult('strategyCallout', 'Enter valid loan details to see your savings.');
      return;
    }

    /* Top summary */
    setResult('oneTwelfthExtra', formatCurrency(result.oneTwelfthExtra));
    setResult('standardPayment', formatCurrency(result.monthlyPayment));
    setResult('diyInterestSavings', formatCurrency(result.diyMonthlyExtra.interestSavingsVsStandard));
    setResult('diyMonthsSaved', formatDuration(result.diyMonthlyExtra.monthsSaved));

    /* Comparison table */
    setResult('standardInterest', formatCurrency(result.standard.totalInterest));
    setResult('standardNetCost', formatCurrency(result.standard.totalCost));
    setResult('biweeklyInterest', formatCurrency(result.biweeklyProgram.totalInterest));
    setResult('biweeklyNetCost', formatCurrency(result.biweeklyProgram.totalCost));
    setResult('diyInterest', formatCurrency(result.diyMonthlyExtra.totalInterest));
    setResult('diyNetCost', formatCurrency(result.diyMonthlyExtra.totalCost));

    /* Honest callout */
    let callout = '';
    if (params.programFee > 0) {
      callout = `<strong class="text-ink-900">The biweekly program and the free DIY method save you the exact same amount in interest.</strong> The program just charges you ${formatCurrency(result.feeWaste)} for the privilege. You can replicate the entire savings free by adding ${formatCurrency(result.oneTwelfthExtra)} to each monthly payment yourself. Same math, no fee.`;
    } else {
      callout = `<strong class="text-ink-900">Adding ${formatCurrency(result.oneTwelfthExtra)} to each monthly payment shaves ${formatDuration(result.diyMonthlyExtra.monthsSaved)} off your loan and saves ${formatCurrency(result.diyMonthlyExtra.interestSavingsVsStandard)} in total interest.</strong> This is the exact same math as a "biweekly" program; no enrollment, no fee, no special account. Just send extra principal each month.`;
    }

    const calloutEl = document.querySelector('[data-result="strategyCallout"]');
    if (calloutEl) calloutEl.innerHTML = callout;
  }

  inputs.forEach((input) => {
    input.addEventListener('input', update);
    input.addEventListener('change', update);
  });

  update();

  document.getElementById('copy-link-btn')?.addEventListener('click', () => {
    const params = getInputs();
    const url = new URL(window.location.href);
    url.search = new URLSearchParams({
      b: params.currentBalance,
      r: params.annualRate,
      t: params.remainingTermMonths,
      f: params.programFee,
    }).toString();
    navigator.clipboard.writeText(url.toString()).then(() => {
      const btn = document.getElementById('copy-link-btn');
      const original = btn.textContent;
      btn.textContent = 'Copied!';
      setTimeout(() => (btn.textContent = original), 2000);
    });
  });

  const urlParams = new URLSearchParams(window.location.search);
  if (urlParams.has('b')) {
    document.getElementById('balance').value = urlParams.get('b') || '';
    document.getElementById('rate').value = urlParams.get('r') || '';
    const t = parseInt(urlParams.get('t') || '0');
    document.getElementById('termYears').value = Math.floor(t / 12);
    document.getElementById('termMonths').value = t % 12;
    document.getElementById('programFee').value = urlParams.get('f') || '0';
    update();
  }
</script>
